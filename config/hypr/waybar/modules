{
 "backlight": {
  "interval": 2,
  "align": 0,
  "rotate": 0,
    "format": "{icon} {percent}",
    "format-icons": ["п—қ", "п—ң", "п—һ", "п—ҹ"],
  //"format-icons": ["пҶ…", "п„‘"] 
    "on-click": "",
    "on-click-middle": "",
    "on-click-right": "",
    "on-update": "",
    "on-scroll-up": "~/.config/hypr/scripts/brightness --inc",
    "on-scroll-down": "~/.config/hypr/scripts/brightness --dec",
    "smooth-scrolling-threshold": 1,
},
 "hyprland/submap": {
   "format": "<span style=\"italic\">пҢһ  {}</span>", // Icon: expand-arrows-alt
   "tooltip": false
},
 "hyprland/window": {
   "format": "{}",
   "max-length": 360
},
 "custom/weather": {
   "format": "{}",
   "format-alt": "{alt}: {}",
   "format-alt-click": "click-right",
   "interval": 3600,
   "return-type": "json",
   "exec": "~/.config/hypr/waybar/scripts/weather.sh",
   "exec-if": "ping wttr.in -c1"
},
  "wlr/workspaces": {
    "format": "{name}",
    //"format": "{name}: {icon}",
    "on-click": "activate",
    "all-outputs": true,
    "sort-by-number": true,
    "format-icons": {
      "1": "1 п„  ",
      "2": "2 пү© ",
      "3": "3 пҒј ",
      "4": "4 пҖ° ",
      "5": "5 пҶ¶ ",
      "6": "6 пҲі ",
      "7": "7 пҺ’ ",
      "8": "8 пӢҶ ",
      "9": "9 пҒӢ ",
      "10": " 10 ",
      "focused": "пҶ’",
      "default": "п„‘",
},
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1",
},
 "idle_inhibitor": {
   "format": "{icon}",
   "format-icons": {
     "activated": "пҒ®",
     "deactivated": "пҒ°"
}
},	
 "battery": {
   "interval": 60,
   "align": 0,
   "rotate": 0,
 //"bat": "BAT1",
 //"adapter": "ACAD",
   "full-at": 100,
   "design-capacity": false,
   "states": {
     "good": 95,
     "warning": 30,
     "critical": 15
},
   "format": "{icon}  {capacity}%",
   "format-charging": "пғ§  {capacity}%",
   "format-plugged": "пҮҰ  {capacity}%",
   "format-full": "{icon} Full",
 //"format-good": "",
    "format-alt": "{icon} {time}",
    "format-icons": ["пү„", "пүғ", "пүӮ", "пүҒ", "пүҖ"],
    "format-time": "{H}h {M}min",
    "tooltip": true,
    "on-click-right": "~/.config/hypr/scripts/glassmorphismToggle"
},
 "clock": {
//"interval": 60,
   "align": 0,
   "rotate": 0,
   "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
   "format": "{:пҖ— %H:%M  пҒі %a, %e %b}",
   //"format-alt": "пҒі {:%a %b %d, %G}",
   "on-click-right": "~/.config/hypr/scripts/changeWallpaper",
},
  "clock#2": {
   "format": "{:пҖ—  %H:%M}",
   "tooltip": true,
   "tooltip-format": "{:пҒі  %A,  %e %B %Y}",
   "on-click-right": "~/.config/hypr/scripts/changeWallpaper",
},
 "cpu": {
 //"interval": 5,
 //"format": "пҳҰ {usage}%",
   "interval": 1,
   "format": "{icon0}{icon1}{icon2}{icon3} {usage:>2}% пӢӣ",
   "format-icons": ["в–Ғ", "в–Ӯ", "в–ғ", "в–„", "в–…", "в–Ҷ", "в–Ү", "в–Ҳ"],
},
 "custom/menu": {
  "format": " п…ј ",
  "tooltip": false,
  "on-click": "$HOME/.config/hypr/scripts/menu",
},
 "custom/power": {
  "format": "пӢө",
  "tooltip": false,
  "on-click": "sh -c '(sleep 0.5s; wlogout --protocol layer-shell)' & disown",
},
 "disk": {
  "interval": 30,
  "format": "пҡ· {free}",
},
 "memory": {
  "interval": 10,
  "format": "{used:0.1f}G пӮҖ",
},
 "network": {
  "interval": 5,
  "format-wifi": "пҮ« {essid}",
  "format-ethernet": "пӣҝ {ipaddr}/{cidr}",
  "format-linked": "пӣҝ {ifname} (No IP)",
  "format-disconnected": "пӘ© Disconnected",
  "format-disabled": "пӘ© Disabled",
  "format-alt": "пғҳ {bandwidthUpBits} | пғ— {bandwidthDownBits}",
  "tooltip-format": "п”Ӯ {ifname} via {gwaddr}",
},
 "custom/weather": {
  "format": " {} ",
  "format-alt": "{alt}: {}",
  "format-alt-click": "click-right",
  "interval": 1800,
  "return-type": "json",
  "exec": "~/.config/hypr/scripts/weather.sh",
  "exec-if": "ping wttr.in -c1"
},
 "custom/updater":{
  "format": "пЈ“ {}",
  "exec": "checkupdates | wc -l",
  "exec-if": "[[ $(checkupdates | wc -l) ]]",
  "interval": 15,
  "on-click": "foot --class update -T update -o font_size=13 -e paru -Syu && notify-send 'The system has been updated' "
},
 "custom/cycle_wall":{
  "format":"пҖҫ",
  "on-click": "~/.config/hypr/scripts/changeWallpaper",
  "tooltip-format": "Change wallpaper",
},
 "pulseaudio": {
   "format": "{icon} {volume}%",
   "format-muted": "п‘Ұ Mute",
   "format-bluetooth": "пҠ“ {volume % {format_source}",
   "format-bluetooth-muted": "пҠ“ Mute",
   "format-icons": {
      "headphone": "пҖҘ",
      "hands-free": "пҖҘ",
      "headset": "пҹҚ",
      "phone": "пӮ•",
      "portable": "пӮ•",
      "car": "пҶ№",
      "default": ["пҖҰ", "пҖ§", "пҖЁ"]
},
  "scroll-step": 5.0,
  "on-click": "~/.config/hypr/scripts/volume --toggle",
  "on-click-right": "pavucontrol",
  "on-scroll-up": "~/.config/hypr/scripts/volume --inc",
  "on-scroll-down": "~/.config/hypr/scripts/volume --dec",
  "smooth-scrolling-threshold": 1,
},
  "pulseaudio#microphone": {
    "format": "{format_source}",
    "format-source": "п„° {volume}%",
    "format-source-muted": "п„ұ",
    "on-click": "~/.config/hypr/scripts/volume --toggle-mic",
    "on-click-right": "pavucontrol",
    "on-scroll-up": "~/.config/hypr/scripts/volume --mic-inc",
    "on-scroll-down": "~/.config/hypr/scripts/volume --mic-dec",
    "scroll-step": 5
},
  "custom/lock_screen": {
    "format": "пҖЈ",
    "on-click": "sh -c '(sleep 0.5s; swaylock)' & disown",
    "tooltip": false
},
 "temperature": {
  "hwmon-path": "/sys/class/hwmon/hwmon3/temp1_input",
  "critical-threshold": 82,
  "format-critical": "{temperatureC}В°C {icon}",
  "format": "{temperatureC}В°C {icon}",
  "format-icons": ["пӢҲ"]
},
 "custom/keybindings": {
  "format":"пӘһ",
  "tooltip": false,
  "on-click": "~/.config/hypr/scripts/keyhint",
},
 "tray": {
    "icon-size": 20,
    "spacing": 8
}
}
